{% extends 'base.html.twig' %}

{% block title %}{{ division.name }} | Rosters{% endblock %}

{% block body %}
<section class="selection-hero">
    <div>
        <p class="selection-kicker">Division</p>
        <h1 class="selection-title">{{ division.name }}</h1>
        <p class="selection-subtitle">{{ division.description }}</p>
    </div>
    <div class="selection-actions">
        <a class="selection-btn ghost" href="{{ path('app_faction_rosters', {id: division.faction.id}) }}">← Back to army rosters</a>
    </div>
</section>

<section class="builder-grid">
    {% if rosterDivisions %}
        {% for rd in rosterDivisions %}
            <div class="builder-card">
                <div class="builder-unit__top">
                    <div>
                        <p class="builder-pill">Roster</p>
                        <h2 class="builder-card__title">{{ rd.name }}</h2>
                        <p class="builder-meta">Created {{ rd.createdAt|date('Y-m-d H:i') }}</p>
                    </div>
                </div>
                <p class="builder-desc">
                    Open to add units to this division instance.
                    {% set pts = rosterTotals[rd.id]|default(0) %}
                    <strong>{{ pts }} pts</strong>
                </p>
                <div class="builder-actions">
                    <a class="selection-btn" href="{{ path('app_roster_division', {id: rd.id}) }}">Open</a>
                    {# @TODO: Add remove platoon option #}
                    <a class="selection-btn" href="{{ path('app_roster_division', {id: rd.id}) }}">Remove</a>
                </div>
            </div>
        {% endfor %}
    {% else %}
        <div class="builder-card">
            <p class="builder-empty">No rosters yet for this division.</p>
        </div>
    {% endif %}
</section>

<section class="builder-actions" style="margin-top: 1rem; display:flex; flex-direction:column; gap:0.75rem;">
    <form method="post" action="{{ path('app_roster_division_create', {id: division.id}) }}" class="auth-form" style="width: 100%; max-width: 100%; display:flex; flex-direction:column; gap:6px; align-items:flex-start;">
        <label class="builder-meta" for="rd-name">New roster name (optional)</label>
        <input id="rd-name" name="name" class="auth-input" placeholder="{{ division.name }} #{{ rosterDivisions|length + 1 }}" style="width:min(100%, 355px);">
        <button type="submit" class="selection-btn" style="width:auto;">Create roster</button>
    </form>
    <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
        <a class="selection-btn ghost" href="{{ path('app_faction_divisions', {id: division.faction.id}) }}">← Back to platoons</a>
        <a class="selection-btn" href="{{ path('app_division_export_pdf', {id: division.id}) }}">Export PDF</a>
    </div>
</section>

<section class="builder-hero-stats builder-stats-inline" style="margin-top: 0.5rem;">
    <div class="builder-stat">
        <span class="builder-stat__label">Total points (all rosters)</span>
        <span class="builder-stat__value">{{ divisionTotal|default(0) }}</span>
    </div>
</section>
{% endblock %}

