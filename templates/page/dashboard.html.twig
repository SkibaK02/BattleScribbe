{% extends 'base.html.twig' %}

{% block title %}Dashboard | BattleScribe{% endblock %}

{% block body %}
<section class="selection-hero">
    <div>
        <p class="selection-kicker">Hello {{ app.user.email }}</p>
        <h1 class="selection-title">Choose your army</h1>
        <p class="selection-subtitle">Pick an army to see available divisions and start building your roster.</p>
    </div>
</section>

<section class="selection-grid">
    {% for faction in factions %}
        <a href="{{ path('app_faction_armies', {id: faction.id}) }}" class="selection-card">
            <div class="selection-card__meta">
                <span class="selection-pill">Army</span>
                <span class="selection-code">{{ faction.name|upper }}</span>
            </div>
            <h2 class="selection-card__title">{{ faction.name }}</h2>
            <p class="selection-card__desc">{{ faction.description|default('No description provided.') }}</p>
            <span class="selection-link">Open army →</span>
        </a>
    {% else %}
        <div class="selection-empty">
            No factions available. Run migrations to seed them.
        </div>
    {% endfor %}
</section>
{% endblock %}

