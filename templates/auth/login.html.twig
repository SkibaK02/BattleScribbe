{% extends 'base.html.twig' %}

{% block title %}Login | CompanyRoster{% endblock %}

{% block body %}
<section class="auth-shell">
    <div class="auth-card">
        <div class="auth-header">
            <p class="auth-kicker">Welcome back</p>
            <h1 class="auth-title">Sign in</h1>
        </div>

        {% if error %}
            <div class="auth-alert error">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}" class="auth-form">
            <label class="auth-label" for="inputEmail">Email</label>
            <input class="auth-input" type="email" id="inputEmail" name="_username" value="{{ last_username }}" required autofocus autocomplete="email">

            <label class="auth-label" for="inputPassword">Password</label>
            <input class="auth-input" type="password" id="inputPassword" name="_password" required autocomplete="current-password">

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button class="auth-btn" type="submit">Log in</button>
        </form>

        <p class="auth-meta">No account yet? <a href="{{ path('app_register_form') }}">Create one</a></p>
    </div>
</section>
{% endblock %}

